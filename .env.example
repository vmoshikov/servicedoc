AI__BASE_URL=https://api.openai.com
AI__API_KEY=sk-...
AI__MODEL=gpt-4o
AI__MAX_TOKENS=2048
AI__BATCH_SIZE=10
AI__RATE_LIMIT_RPM=60
AI__RETRY_MAX_ATTEMPTS=5

GIT__GITHUB_TOKEN=ghp_...
GIT__GITLAB_TOKEN=glpat-...
GIT__CLONE_TIMEOUT_SECONDS=120

CACHE__CACHE_DIR=/tmp/servicedoc_cache
