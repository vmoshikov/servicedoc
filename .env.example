CACHE__AI_RESPONSE_CACHE=true

OUTPUT_DIR=./servicedoc_output
MAX_CONCURRENT_PARSERS=8
MAX_CONCURRENT_AI_CALLS=3
REPORT_LANGUAGE=ru
